# All options are optional, remove those you do not need
VITE_CUSTOM_API_ENDPOINT=
VITE_DEFAULT_API_ENDPOINT=
# DANGER: setting this embeds your API key as plaintext in the compiled JS bundle.
# Anyone who loads the deployed site can extract it with: grep 'sk-' index.js
# Only use this for single-user LOCAL installs where you are the only person with access.
VITE_OPENAI_API_KEY=
VITE_DEFAULT_SYSTEM_MESSAGE=     # Remove this line if you want to use the default system message of chatty-buddy
VITE_GOOGLE_CLIENT_ID=           # for syncing data with google drive
